# GitHub / deploy
FAST_FASHION_HOST=127.0.0.1
FAST_FASHION_PORT=8765

# Hugging Face (optional if dataset is public, but keep for private/restricted access)
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# Kaggle credentials
KAGGLE_USERNAME=
KAGGLE_KEY=

# S3 / AWS uploads (secrets only in your local .env or runtime environment)
FAST_FASHION_S3_PASSWORD=
S3_ENDPOINT_URL=
S3_BUCKET=
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Local cache path for kagglehub if you choose to use it later
KAGGLEHUB_CACHE=
